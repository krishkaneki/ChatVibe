{
  "compilerOptions": {
    "lib": ["esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": "./dist",
    "target": "es2017",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["server/**/*.ts"],
  "exclude": ["node_modules"]
}
